# Camera publisher environment for backend.publisher_yolo.main
#
# Recommended first test:
# Use the HTTP stream because you already confirmed it works in the browser.
# If RTSP also works later, replace CAMERA_STREAM_URL with the RTSP URL.

# Camera input
CAMERA_STREAM_URL="http://192.168.100.168:8081/video"
CAMERA_USERNAME="admin"
CAMERA_PASSWORD="admin"
# Alternative if you later confirm RTSP works:
# CAMERA_STREAM_URL="rtsp://192.168.100.168:8554/live"
# CAMERA_USERNAME="admin"
# CAMERA_PASSWORD="admin"

# Door and publisher identity
DOOR_ID="door-a"
PUBLISHER_ID="iphone16pro-camera"
MQTT_CLIENT_ID="publisher-yolo"

# MQTT broker used by the rest of the system
MQTT_HOST="localhost"
MQTT_PORT="1883"
MQTT_KEEPALIVE="60"

# YOLO model and detection settings
YOLO_MODEL="yolov8n.pt"
YOLO_CONFIDENCE="0.35"

# Crossing calibration
# Draw an imaginary line across the doorway in the camera view.
# Start with rough values, then adjust after your first live test.
LINE_START="100,100"
LINE_END="540,100"

# Direction mapping
# If enter/leave is reversed, switch this to positive_to_negative.
ENTER_WHEN="negative_to_positive"
